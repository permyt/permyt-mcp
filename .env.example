# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Encrypted model fields (generate unique values for production)
SECURED_FIELDS_KEY=generate-a-fernet-key
SECURED_FIELDS_HASH_SALT=generate-random-hex

# PERMYT connector
PERMYT_SERVICE_ID=your-service-id
PERMYT_PUBLIC_KEY_PATH=keys/permyt/public.pem
PRIVATE_KEY_PATH=keys/connector/private.pem
BASE_URL=http://localhost:9020
NONCE_TTL_SECONDS=60
PERMYT_HOST=http://localhost:8000

# MCP OAuth (optional — defaults derived from BASE_URL)
# MCP_ISSUER_URL=http://localhost:9020/mcp
# MCP_SERVER_URL=http://localhost:9020/mcp
# DISABLE_DRF_TOKEN_FALLBACK=false
